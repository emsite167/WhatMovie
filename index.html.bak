  'ridley scott':      [{t:'Golden Globe',cat:'Cecil B. DeMille Award',y:'2024',cls:'other',ico:'🌟'}],
  'denis villeneuve':  [{t:'BAFTA',cat:'Meilleur Réalisateur — Dune',y:'2022',cls:'other',ico:'🎬'}],
  'quentin tarantino': [{t:'Oscar',cat:'Meilleur Scénario × 2',y:'1995/2013',cls:'oscar',ico:'🏆'}],
  'james cameron':     [{t:'Oscar',cat:'Meilleur Réalisateur × 2',y:'1998/2010',cls:'oscar',ico:'🏆'}],
  'peter jackson':     [{t:'Oscar',cat:'Meilleur Réalisateur — LOTR',y:'2004',cls:'oscar',ico:'🏆'}],
  'francis ford coppola':[{t:'Oscar',cat:'Meilleur Réalisateur — Le Parrain II',y:'1975',cls:'oscar',ico:'🏆'}],
  'jane campion':      [{t:'Oscar',cat:'Meilleure Réalisatrice — La Leçon de Piano · The Power of the Dog',y:'mult.',cls:'oscar',ico:'🏆'}],
  'kathryn bigelow':   [{t:'Oscar',cat:'Meilleure Réalisatrice — Démineurs (1ère femme)',y:'2010',cls:'oscar',ico:'🏆'}],
};

function getFilmAwards(det){
  const t = (det.title||det.name||'').toLowerCase();
  const o = (det.original_title||det.original_name||'').toLowerCase();
  return AWARDS_DB[t] || AWARDS_DB[o] || [];
}
function getPersonAwards(name){
  const n = (name||'').toLowerCase();
  return PERSON_AWARDS[n] || [];
}

/* ══ CLÉ / TMDB ══ */
function getKey(){ return localStorage.getItem('wm_k') || ''; }
function saveKey(){
  const k = document.getElementById('tmdb-inp').value.trim();
  if(!k) return;
  localStorage.setItem('wm_k', k);
  document.getElementById('key-ok').style.display = 'inline';
  setTimeout(() => document.getElementById('setup-banner').style.display = 'none', 1200);
}
async function tmdb(path, lang='fr-FR'){
  const k = getKey(); if(!k) throw new Error('Clé TMDB manquante');
  const sep = path.includes('?')?'&':'?';
  const r = await fetch(`https://api.themoviedb.org/3${path}${sep}api_key=${k}&language=${lang}`);
  if(!r.ok){ const e=await r.json().catch(()=>{}); throw new Error((e&&e.status_message)||`Erreur TMDB ${r.status}`); }
  return r.json();
}

/* ══ INIT ══ */
window.addEventListener('DOMContentLoaded', () => {
  const k = getKey();
  if(k){ document.getElementById('tmdb-inp').value=k; document.getElementById('setup-banner').style.display='none'; }
  renderStep();
  document.addEventListener('click', e => { if(!document.getElementById('swrap').contains(e.target)) closeDrop(); });
});

function goHome(){ clearSearch(); document.getElementById('sinp').value=''; document.getElementById('sbtn').disabled=true; }
function switchTab(n){ document.querySelectorAll('.page').forEach(p=>p.classList.remove('active')); document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active')); document.getElementById('page-'+n).classList.add('active'); document.getElementById('tab-'+n).classList.add('active'); }

/* ══ AUTOCOMPLETE ══ */
let sugT=null, sugI=-1, sugL=[];
function onInp(){
  const q=document.getElementById('sinp').value.trim();
  document.getElementById('sbtn').disabled=q.length<2;
  clearTimeout(sugT);
  if(q.length<2){closeDrop();return;}
  sugT=setTimeout(()=>fetchSug(q),280);
}
async function fetchSug(q){
  if(!getKey()) return;
  try{
    const [mv,tv,pe]=await Promise.all([
      tmdb(`/search/movie?query=${enc(q)}&include_adult=false`),
      tmdb(`/search/tv?query=${enc(q)}&include_adult=false`),
      tmdb(`/search/person?query=${enc(q)}`)
    ]);
    const movies=(mv.results||[]).slice(0,4).map(r=>({...r,_t:'movie'}));
    const shows=(tv.results||[]).slice(0,3).map(r=>({...r,_t:'tv'}));
    const people=(pe.results||[]).slice(0,3).map(r=>({...r,_t:'person'}));
    const all=[...movies,...shows,...people].sort((a,b)=>(b.popularity||0)-(a.popularity||0)).slice(0,10);
    showDrop(all,q);
  }catch(e){}
}
function showDrop(items,q){
  const box=document.getElementById('sdrop'), inp=document.getElementById('sinp');
  if(!items.length){closeDrop();return;}
  sugL=items; sugI=-1;
  const movies=items.filter(i=>i._t==='movie');
  const shows=items.filter(i=>i._t==='tv');
  const people=items.filter(i=>i._t==='person');
  let html='';
  function itemHtml(r){
    const i=items.indexOf(r);
    if(r._t==='movie'){
      const yr=(r.release_date||'').slice(0,4);
      const sc=r.vote_average?(Math.round(r.vote_average*10)/10).toFixed(1):'';
      const ph=r.poster_path?`<img class="sposter" src="${IMGS}${r.poster_path}" loading="lazy">`:`<div class="sposter-ph">🎬</div>`;
      return `<div class="sitem" onmousedown="pickSug(${i})">${ph}<div class="sname"><div class="sname-t">${hl(esc(r.title),q)}</div><div class="sname-s">${yr}${r.original_title&&r.original_title!==r.title?' · '+esc(r.original_title):''}</div></div>${sc?`<div class="sscore">★ ${sc}</div>`:''}</div>`;
    } else if(r._t==='tv'){
      const yr=(r.first_air_date||'').slice(0,4);
      const sc=r.vote_average?(Math.round(r.vote_average*10)/10).toFixed(1):'';
      const ph=r.poster_path?`<img class="sposter" src="${IMGS}${r.poster_path}" loading="lazy">`:`<div class="sposter-ph">📺</div>`;
      return `<div class="sitem" onmousedown="pickSug(${i})">${ph}<div class="sname"><div class="sname-t">${hl(esc(r.name),q)}</div><div class="sname-s">${yr}</div></div>${sc?`<div class="sscore">★ ${sc}</div>`:''}</div>`;
    } else {
      const kn=(r.known_for||[]).map(f=>f.title||f.name).slice(0,2).join(', ');
      const dept=r.known_for_department||'';
      const dFr=dept==='Acting'?'Acteur·rice':dept==='Directing'?'Réalisateur':dept==='Production'?'Producteur':dept;
      const ph=r.profile_path?`<img class="sposter" src="${IMGS}${r.profile_path}" loading="lazy" style="border-radius:50%">`:`<div class="sposter-ph" style="border-radius:50%">👤</div>`;
      return `<div class="sitem" onmousedown="pickSug(${i})">${ph}<div class="sname"><div class="sname-t">${hl(esc(r.name),q)}</div><div class="sname-s">${dFr}${kn?' · '+esc(kn):''}</div></div></div>`;
    }
  }
  if(movies.length) html+=`<div class="drop-sec"><div class="drop-lbl">🎬 Films</div>${movies.map(itemHtml).join('')}</div>`;
  if(shows.length)  html+=`<div class="drop-sec"><div class="drop-lbl">📺 Séries</div>${shows.map(itemHtml).join('')}</div>`;
  if(people.length) html+=`<div class="drop-sec"><div class="drop-lbl">👤 Personnes</div>${people.map(itemHtml).join('')}</div>`;
  box.innerHTML=html; box.classList.add('open'); inp.classList.add('open');
}
function hl(t,q){ try{return t.replace(new RegExp('('+q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')','gi'),'<mark>$1</mark>');}catch{return t;} }
function closeDrop(){ document.getElementById('sdrop').classList.remove('open'); document.getElementById('sinp').classList.remove('open'); sugI=-1; }
function pickSug(i){
  const it=sugL[i]; if(!it) return;
  const name=it._t==='person'?it.name:(it.title||it.name||'');
  document.getElementById('sinp').value=name;
  document.getElementById('sbtn').disabled=false;
  closeDrop();
  if(it._t==='movie'||it._t==='tv') openModal(it.id,it._t);
  else { const dept=it.known_for_department||''; const role=dept==='Directing'?'director':dept==='Production'?'producer':'actor'; loadPerson(it.id,it.name,role); }
}

/* Bouton "Films similaires" depuis la recherche texte */
function triggerSimilar(movieId, title, media){ loadSimilar(movieId, title, media); }
}
function onKD(e){
  const box=document.getElementById('sdrop'); const items=box.querySelectorAll('.sitem');
  if(!box.classList.contains('open')){ if(e.key==='Enter') doSearch(); return; }
  if(e.key==='ArrowDown'){ e.preventDefault(); sugI=Math.min(sugI+1,items.length-1); items.forEach((el,i)=>el.classList.toggle('on',i===sugI)); }
  else if(e.key==='ArrowUp'){ e.preventDefault(); sugI=Math.max(sugI-1,-1); items.forEach((el,i)=>el.classList.toggle('on',i===sugI)); }
  else if(e.key==='Enter'){ e.preventDefault(); if(sugI>=0) pickSug(sugI); else{closeDrop();doSearch();} }
  else if(e.key==='Escape') closeDrop();
}

/* ══ RECHERCHE TEXTE ══ */
function clearSearch(){
  document.getElementById('rres').style.display='none';
  document.getElementById('serr').style.display='none';
  document.getElementById('actor-detail').innerHTML='';
  document.getElementById('flist-wrap').innerHTML='';
  document.getElementById('rlabel').textContent='';
}
async function doSearch(){
  const q=document.getElementById('sinp').value.trim();
  if(q.length<2) return;
  if(!getKey()){ document.getElementById('setup-banner').style.display='flex'; showErr('serr',"⚠️ Entre d'abord ta clé TMDB en haut."); return; }
  closeDrop(); clearSearch(); document.getElementById('serr').style.display='none';
  document.getElementById('sload').style.display='block';
  try{
    const [mv,tv,pe]=await Promise.all([
      tmdb(`/search/movie?query=${enc(q)}&include_adult=false`),
      tmdb(`/search/tv?query=${enc(q)}&include_adult=false`),
      tmdb(`/search/person?query=${enc(q)}`)
    ]);
    const movies=(mv.results||[]).slice(0,5).map(r=>({...r,_t:'movie'}));
    const shows=(tv.results||[]).slice(0,4).map(r=>({...r,_t:'tv'}));
    const people=(pe.results||[]).slice(0,2);
    let total=movies.length+shows.length+people.length;
    if(!total){noRes(q);document.getElementById('sload').style.display='none';return;}
    document.getElementById('rlabel').textContent=total+' résultat'+(total>1?'s':'')+' pour "'+q+'"';
    if(people.length&&(people[0].popularity||0)>8){
      const dept=people[0].known_for_department||'';
      const role=dept==='Directing'?'director':dept==='Production'?'producer':'actor';
      await renderActorCard(people[0].id,role);
    }
    const wrap=document.getElementById('flist-wrap'); wrap.innerHTML='';
    const combined=[...movies,...shows].sort((a,b)=>(b.popularity||0)-(a.popularity||0));
    if(combined.length){
      const list=document.createElement('div'); list.className='flist';
      combined.forEach(f=>list.appendChild(makeCard(f)));
      wrap.appendChild(list);
    }
    document.getElementById('rres').style.display='block';
  }catch(e){console.error(e);showErr('serr','❌ '+(e.message||'Erreur réseau'));}
  document.getElementById('sload').style.display='none';
}

/* ══ PAGE PERSONNE ══ */
async function loadPerson(pid,name,role){
  clearSearch(); document.getElementById('sload').style.display='block';
  try{
    await renderActorCard(pid,role);
    const cr=await tmdb(`/person/${pid}/combined_credits`);
    // Filtre et trie : films puis séries, TV show en dernier, par popularité
    let cast=[];
    if(role==='actor'){
      const raw=(cr.cast||[]).filter(f=>f.poster_path&&(f.vote_count||0)>3);
      // Sépare films, séries, tv shows
      const films=raw.filter(f=>f.media_type==='movie').sort((a,b)=>(b.popularity||0)-(a.popularity||0));
      const series=raw.filter(f=>f.media_type==='tv'&&(f.episode_count||0)>2).sort((a,b)=>(b.popularity||0)-(a.popularity||0));
      const tvShows=raw.filter(f=>f.media_type==='tv'&&(f.episode_count||0)<=2).sort((a,b)=>(b.popularity||0)-(a.popularity||0));
      cast=[...films.slice(0,12),...series.slice(0,6),...tvShows.slice(0,4)].map((f,i)=>({...f,_t:f.media_type,_r:'Acteur',_istvshow:f.media_type==='tv'&&(f.episode_count||0)<=2}));
    } else if(role==='director'){
      cast=(cr.crew||[]).filter(f=>f.job==='Director'&&f.poster_path).sort((a,b)=>(b.vote_count||0)-(a.vote_count||0)).slice(0,14).map(f=>({...f,_t:f.media_type||'movie',_r:'Réalisateur'}));
    } else {
      cast=(cr.crew||[]).filter(f=>['Producer','Executive Producer'].includes(f.job)&&f.poster_path).sort((a,b)=>(b.vote_count||0)-(a.vote_count||0)).slice(0,14).map(f=>({...f,_t:f.media_type||'movie',_r:'Producteur'}));
    }
    document.getElementById('rlabel').textContent='Filmographie ('+cast.length+' œuvres)';
    const wrap=document.getElementById('flist-wrap'); wrap.innerHTML='';
    // Section films
    const filmsOnly=cast.filter(f=>f._t==='movie');
    const seriesOnly=cast.filter(f=>f._t==='tv'&&!f._istvshow);
    const tvOnly=cast.filter(f=>f._istvshow);
    if(filmsOnly.length){
      const h=document.createElement('div'); h.className='section-header'; h.textContent='🎬 Films'; wrap.appendChild(h);
      const list=document.createElement('div'); list.className='flist';
      filmsOnly.forEach(f=>list.appendChild(makeCard(f))); wrap.appendChild(list);
    }
    if(seriesOnly.length){
      const h=document.createElement('div'); h.className='section-header'; h.textContent='📺 Séries'; wrap.appendChild(h);
      const list=document.createElement('div'); list.className='flist';
      seriesOnly.forEach(f=>list.appendChild(makeCard(f))); wrap.appendChild(list);
    }
    if(tvOnly.length){
      const h=document.createElement('div'); h.className='section-header'; h.textContent='📡 Émissions & Apparitions TV'; wrap.appendChild(h);
      const list=document.createElement('div'); list.className='flist';
      tvOnly.forEach(f=>list.appendChild(makeCard(f))); wrap.appendChild(list);
    }
    document.getElementById('rres').style.display='block';
  }catch(e){console.error(e);showErr('serr','❌ '+e.message);}
  document.getElementById('sload').style.display='none';
}

async function renderActorCard(pid,role){
  const roleLabels={actor:'Acteur / Actrice',director:'Réalisateur',producer:'Producteur'};
  try{
    const [det,detEN]=await Promise.all([tmdb(`/person/${pid}`),tmdb(`/person/${pid}`,'en-US')]);
    const ph=det.profile_path?`<img class="actor-photo" src="${IMGM}${det.profile_path}" alt="">`:`<div class="actor-photo-ph">👤</div>`;
    let age='';
    if(det.birthday){ const b=new Date(det.birthday); if(!det.deathday) age=Math.floor((new Date()-b)/(365.25*24*3600*1000))+' ans'; else age=Math.floor((new Date(det.deathday)-b)/(365.25*24*3600*1000))+' ans (†'+det.deathday.slice(0,4)+')'; }
    const pills=[age,det.place_of_birth?'📍 '+det.place_of_birth:'',det.birthday?'🎂 '+det.birthday.split('-').reverse().join('/'):''].filter(Boolean).map(x=>`<span class="actor-pill">${esc(x)}</span>`).join('');
    // Bio
    let bio=det.biography||'';
    if(bio.length<100&&detEN.biography) bio=detEN.biography;
    const bioId='bio-'+pid;
    // Récompenses personne
    const pAwards=getPersonAwards(det.name);
    const awardsHtml=pAwards.length?`<div class="person-awards">${pAwards.map(a=>`<div class="person-award ${a.cls}" title="${esc(a.cat)} (${a.y})">${a.ico} ${a.t} — ${esc(a.cat)}</div>`).join('')}</div>`:'';
    document.getElementById('actor-detail').innerHTML=`
      <div class="actor-card">
        <div class="actor-top">
          ${ph}
          <div style="flex:1;min-width:0">
            <div class="actor-name">${esc(det.name)}</div>
            <div class="actor-badge">${roleLabels[role]||role}</div>
            <div class="actor-pills">${pills}</div>
          </div>
        </div>
        ${awardsHtml}
        ${bio?`<div>
          <div class="actor-bio truncated" id="${bioId}">${esc(bio)}</div>
          <button class="btn-bio" id="btn-${bioId}" onclick="toggleBio('${bioId}')">Lire la biographie complète ↓</button>
        </div>`:''}
      </div>`;
  }catch(e){ document.getElementById('actor-detail').innerHTML=''; }
}

function toggleBio(id){
  const el=document.getElementById(id), btn=document.getElementById('btn-'+id);
  if(el.classList.contains('truncated')){ el.classList.remove('truncated'); btn.textContent='Réduire ↑'; }
  else { el.classList.add('truncated'); btn.textContent='Lire la biographie complète ↓'; }
}

/* ══ MAKE CARD ══ */
function makeCard(f){
  const card=document.createElement('div'); card.className='fcard';
  const media=f._t||'movie';
  card.onclick=()=>openModal(f.id,media);
  const raw=f.vote_average; const sc=raw?(Math.round(raw*10)/10).toFixed(1):null; const cls=sc>=7?'g':sc>=5?'m':'l';
  const title=f.title||f.name||'';
  const yr=(f.release_date||f.first_air_date||'').slice(0,4);
  const ph=f.poster_path?`<img class="fthumb" src="${IMGS}${f.poster_path}" loading="lazy">`:`<div class="fthumb-ph">${media==='tv'?'📺':'🎬'}</div>`;
  const ov=f.overview?f.overview.slice(0,160)+(f.overview.length>160?'…':''):'';
  // Récompenses sur la carte
  const filmKey=(title||'').toLowerCase();
  const origKey=(f.original_title||f.original_name||'').toLowerCase();
  const filmAw=AWARDS_DB[filmKey]||AWARDS_DB[origKey]||[];
  let chips='';
  if(f._r){ const ri=f._r==='Acteur'?'🎭':f._r==='Réalisateur'?'🎥':'🎙'; chips+=`<span class="chip hl">${ri} ${f._r}</span>`; }
  if(media==='tv'&&!f._istvshow) chips+=`<span class="chip serie">📺 Série</span>`;
  if(f._istvshow) chips+=`<span class="chip tvshow">📡 Émission TV</span>`;
  const gmap=media==='tv'?GT:GM;
  if(f.genre_ids) f.genre_ids.slice(0,2).forEach(id=>{ if(gmap[id]) chips+=`<span class="chip genre">${gmap[id]}</span>`; });
  filmAw.slice(0,1).forEach(a=>{ chips+=`<span class="award-chip ${a.cls}">${a.ico} ${a.t} — ${a.y}</span>`; });
  card.innerHTML=ph+`<div class="fbody"><div class="ftitle">${esc(title)}</div><div class="fmeta">${yr}</div>${ov?`<div class="foverview">${ov}</div>`:''}<div class="fhint">Cliquer pour la fiche complète →</div>${chips?`<div class="fchips">${chips}</div>`:''}</div>${sc?`<div class="fscore ${cls}">★ ${sc}</div>`:''}`;
  return card;
}

function noRes(q){ document.getElementById('flist-wrap').innerHTML=`<div class="nores"><span>🎞</span>Aucun résultat pour "<strong>${esc(q)}</strong>".</div>`; document.getElementById('rres').style.display='block'; }

/* ══ MODAL ══ */
async function openModal(id,media='movie'){
  trailerKey=null;
  document.getElementById('overlay').style.display='block';
  document.body.style.overflow='hidden';
  ['mtitle','morig','mpills','mawards-block','mratings','msynopsis','mgenres','mplatforms','mcrew','mcast','plat-label'].forEach(k=>{ const el=document.getElementById(k); if(el) el.innerHTML=k==='mtitle'?'Chargement…':k==='msynopsis'?'Chargement…':''; });
  document.getElementById('mback').innerHTML='<div class="mback-ph"></div>';
  document.getElementById('mpwrap').innerHTML='<div class="mposter-ph">🎬</div>';
  document.getElementById('playbtn').style.opacity='1'; document.getElementById('playbtn').style.pointerEvents='auto';
  document.getElementById('playlbl').textContent='▶ Bande-annonce';
  try{
    const ep=media==='tv'?'tv':'movie';
    const [det,vids,provRaw]=await Promise.all([
      tmdb(`/${ep}/${id}?append_to_response=credits`),
      tmdb(`/${ep}/${id}/videos`),
      fetch(`https://api.themoviedb.org/3/${ep}/${id}/watch/providers?api_key=${getKey()}`).then(r=>r.json()).catch(()=>null)
    ]);
    const creds=det.credits||{cast:[],crew:[]};
    if(!det.credits){ try{ const c=await tmdb(`/${ep}/${id}/credits`); creds.cast=c.cast||[]; creds.crew=c.crew||[]; }catch{} }

    if(det.backdrop_path) document.getElementById('mback').innerHTML=`<img class="mback" src="${IMGB}${det.backdrop_path}" loading="lazy">`;
    if(det.poster_path) document.getElementById('mpwrap').innerHTML=`<img class="mposter" src="${IMG}${det.poster_path}" onclick="openTrailer()" title="▶ Voir la bande-annonce">`;

    const tr=(vids.results||[]).find(v=>v.type==='Trailer'&&v.site==='YouTube')||(vids.results||[]).find(v=>v.site==='YouTube');
    if(tr) trailerKey=tr.key;
    else{ document.getElementById('playbtn').style.opacity='.3'; document.getElementById('playbtn').style.pointerEvents='none'; document.getElementById('playlbl').textContent='Pas de bande-annonce'; }

    const title=det.title||det.name||'';
    document.getElementById('mtitle').textContent=title;
    const orig=det.original_title||det.original_name||'';
    if(orig&&orig!==title) document.getElementById('morig').textContent=orig;

    const yr=(det.release_date||det.first_air_date||'').slice(0,4);
    let rt=''; if(det.runtime) rt=`${Math.floor(det.runtime/60)}h ${det.runtime%60}min`; else if(det.episode_run_time&&det.episode_run_time.length) rt=`~${det.episode_run_time[0]}min/épisode`;
    const seas=det.number_of_seasons?`${det.number_of_seasons} saison${det.number_of_seasons>1?'s':''} · ${det.number_of_episodes} épisodes`:'';
    const pills=[yr,rt,seas,media==='tv'?'📺 Série':'🎬 Film'].filter(Boolean);
    document.getElementById('mpills').innerHTML=pills.map(p=>`<span class="mpill${p==='📺 Série'?' serie':''}">${p}</span>`).join('');

    // RÉCOMPENSES FILM — bloc dédié
    const aw=getFilmAwards(det);
    if(aw.length){
      document.getElementById('mawards-block').innerHTML=`
        <div class="awards-block">
          <div class="awards-block-title">🏆 Récompenses</div>
          <div class="awards-list">${aw.map(a=>`
            <div class="award-item">
              <div class="award-item-ico">${a.ico}</div>
              <div class="award-item-info">
                <div class="award-item-title">${a.t} ${a.y}</div>
                <div class="award-item-detail">${esc(a.cat)}</div>
              </div>
            </div>`).join('')}
          </div>
        </div>`;
    }

    // NOTES
    const sc=det.vote_average?(Math.round(det.vote_average*10)/10).toFixed(1):null;
    const cls=sc>=7?'green':sc>=5?'gold':'red';
    const ur=userRatings[id]||0;
    let rh=sc?`<div class="rbox"><div class="rsrc">TMDB</div><div class="rval ${cls}">★ ${sc}</div>${det.vote_count?`<div class="rsub">${det.vote_count.toLocaleString('fr-FR')} votes</div>`:''}</div>`:'';
    rh+=`<div class="rbox"><div class="rsrc">Ma note</div><div class="stars" id="stars">${[1,2,3,4,5].map(s=>`<span class="star${ur>=s?' on':''}" onclick="setRating('${id}',${s})">★</span>`).join('')}</div><div class="rsub" id="rlbl">${ur?ur+' / 5':'Non noté'}</div></div>`;
    document.getElementById('mratings').innerHTML=rh;

    document.getElementById('msynopsis').textContent=det.overview||'Aucun synopsis disponible.';
    document.getElementById('mgenres').innerHTML=(det.genres||[]).map(g=>`<span class="gtag">${g.name}</span>`).join('');
    buildPlatforms(provRaw);

    const dirs=(creds.crew||[]).filter(c=>c.job==='Director').slice(0,3);
    const prods=(creds.crew||[]).filter(c=>['Producer','Executive Producer'].includes(c.job)).slice(0,2);
    document.getElementById('mcrew').innerHTML=[...dirs,...prods].map(c=>{
      const ph=c.profile_path?`<img class="cphoto" src="${IMGS}${c.profile_path}">`:`<div class="cphoto-ph">👤</div>`;
      const j=c.job==='Director'?'Réalisateur':c.job==='Producer'?'Producteur':'Prod. Exécutif';
      const cr=c.job==='Director'?'director':'producer';
      return `<div class="crew-card" onclick="byPerson(${c.id},'${cr}')">${ph}<div><div class="cname">${esc(c.name)}</div><div class="cjob">${j}</div></div></div>`;
    }).join('');

    document.getElementById('mcast').innerHTML=(creds.cast||[]).slice(0,16).map(a=>{
      const ph=a.profile_path?`<img class="caphoto" src="${IMGS}${a.profile_path}">`:`<div class="caphoto-ph">👤</div>`;
      return `<div class="castcard" onclick="byPerson(${a.id},'actor')">${ph}<div class="caname">${esc(a.name)}</div><div class="cachar">${esc(a.character||'')}</div></div>`;
    }).join('');

    // Bouton films similaires
    const simBtn = document.createElement('button');
    simBtn.style.cssText='margin-top:1.5rem;width:100%;font-family:inherit;font-size:14px;font-weight:500;color:var(--accent);background:var(--abg);border:1.5px solid rgba(196,75,43,.25);border-radius:10px;padding:12px;cursor:pointer;transition:background .15s';
    simBtn.textContent='🎬 Voir 10 films similaires →';
    simBtn.onmouseover=()=>simBtn.style.background='rgba(196,75,43,.14)';
    simBtn.onmouseout=()=>simBtn.style.background='var(--abg)';
    simBtn.onclick=()=>{ closeModal(); loadSimilar(id, title, media); switchTab('search'); };
    document.getElementById('mcast').after(simBtn);

  }catch(e){ document.getElementById('msynopsis').textContent='Erreur : '+e.message; }
}

function buildPlatforms(data){
  const el=document.getElementById('mplatforms'), lbl=document.getElementById('plat-label');
  if(!data||!data.results){ el.innerHTML='<span style="font-size:13px;color:var(--text3)">Non disponible</span>'; return; }
  const region=data.results['FR']||data.results['BE']||data.results['US']||Object.values(data.results)[0];
  if(!region){ el.innerHTML='<span style="font-size:13px;color:var(--text3)">Non référencé</span>'; return; }
  const platforms=[];
  if(region.flatrate) region.flatrate.forEach(p=>{ if(!platforms.find(x=>x.provider_id===p.provider_id)) platforms.push({...p,typeFr:'Streaming'}); });
  if(!platforms.length&&region.rent) region.rent.slice(0,2).forEach(p=>platforms.push({...p,typeFr:'Location'}));
  if(!platforms.length&&region.buy)  region.buy.slice(0,2).forEach(p=>platforms.push({...p,typeFr:'Achat'}));
  if(!platforms.length){ el.innerHTML='<span style="font-size:13px;color:var(--text3)">Non disponible en streaming</span>'; return; }
  lbl.textContent=data.results['FR']?'Disponible en France :':'Disponible (international) :';
  el.innerHTML=platforms.slice(0,5).map((p,i)=>{
    const isB=i===0;
    const logo=p.logo_path?`<img class="pico" src="${LOGO}${p.logo_path}" alt="">`:'';
    return `<div class="platform${isB?' best':''}">${logo}<span>${esc(p.provider_name)}</span><span style="font-size:10px;color:var(--text3);margin-left:3px">${p.typeFr}</span>${isB?`<span class="best-badge">⭐ Recommandé</span>`:''}</div>`;
  }).join('');
}

function setRating(mid,v){
  userRatings[mid]=v; localStorage.setItem('wm_r',JSON.stringify(userRatings));
  document.querySelectorAll('#stars .star').forEach((s,i)=>s.classList.toggle('on',i<v));
  document.getElementById('rlbl').textContent=v+' / 5';
}
function openTrailer(){ if(trailerKey) window.open(`https://www.youtube.com/watch?v=${trailerKey}`,'_blank'); }
function closeModal(){ document.getElementById('overlay').style.display='none'; document.body.style.overflow=''; }
function overlayClick(e){ if(e.target===document.getElementById('overlay')) closeModal(); }

async function byPerson(pid,role){
  closeModal();
  try{
    const d=await tmdb(`/person/${pid}`);
    document.getElementById('sinp').value=d.name;
    switchTab('search');
    await loadPerson(pid,d.name,role);
  }catch(e){ console.error(e); }
}

/* ══ QUIZ ══ */
const QS=[
  {
    id:'lastfilm',
    meta:"Étape 1 — Ton point de départ",
    title:'Quel est ton dernier film ou série coup de cœur ?',
    type:'text',
    placeholder:'Ex : Inception, Breaking Bad, Parasite… (optionnel mais très utile)',
    hint:'L\'IA s\'en sert pour calibrer précisément tes goûts'
  },
  {
    id:'mood',
    meta:"Étape 2 — État d'esprit",
    title:'Comment tu te sens ce soir ?',
    type:'grid',
    opts:[
      {v:'aventurier et énergique',i:'⚡',l:'Aventurier',s:"Envie d'action"},
      {v:'mélancolique et nostalgique',i:'🌧',l:'Mélancolique',s:'Pensif, nostalgique'},
      {v:'curieux et intellectuel',i:'🔍',l:'Curieux',s:'Envie de réfléchir'},
      {v:'détendu et calme',i:'🌙',l:'Détendu',s:'Soirée tranquille'},
      {v:"tendu, besoin d'adrénaline",i:'🔥',l:'Tendu',s:'Besoin de décharge'},
      {v:"émotif, envie d'être touché",i:'💫',l:'Touché',s:"Envie d'être ému"},
    ]
  },
  {
    id:'depth',
    meta:"Étape 3 — Niveau d'engagement",
    title:'Tu veux quelque chose qui te demande quoi ?',
    type:'grid',
    opts:[
      {v:'réflexion profonde et complexe',i:'🧠',l:'Réfléchir',s:'Prise de tête'},
      {v:'narration captivante du début à la fin',i:'📖',l:'Être absorbé',s:'Bonne histoire'},
      {v:'beauté visuelle et atmosphère',i:'🎨',l:'Contempler',s:'Beau à regarder'},
      {v:'divertissement pur sans prise de tête',i:'🍿',l:'Se divertir',s:'Facile à regarder'},
    ]
  },
  {
    id:'theme',
    meta:'Étape 4 — Univers',
    title:'Dans quel univers tu veux plonger ?',
    type:'grid',
    opts:[
      {v:'crime enquête thriller',i:'🕵',l:'Thriller',s:'Crime, suspense'},
      {v:'science-fiction technologie futur',i:'🚀',l:'Sci-fi',s:'Futur, tech'},
      {v:'drame humain relations émotions',i:'🎭',l:'Drame',s:'Émotions profondes'},
      {v:'horreur psychologique angoisse',i:'👁',l:'Horreur',s:'Tension, peur'},
      {v:'histoire vraie biopic faits réels',i:'📰',l:'Histoire vraie',s:'Basé sur des faits'},
      {v:'fantastique mystère étrange',i:'🌀',l:'Fantastique',s:'Magie, mystère'},
      {v:'comédie humour légèreté',i:'😂',l:'Comédie',s:'Rires garantis'},
      {v:'romance amour relations',i:'💕',l:'Romance',s:'Amour, relations'},
    ]
  },
  {
    id:'tolerance',
    meta:"Étape 5 — Tolérance",
    title:'Ton niveau de tolérance aux scènes difficiles ?',
    type:'grid',
    opts:[
      {v:'tout accepté, violence horreur gore ok',i:'💪',l:'Tout ok',s:'Aucune limite'},
      {v:'violence modérée ok mais pas de gore',i:'👍',l:'Modéré',s:'Pas de gore'},
      {v:'rien de choquant, contenu light uniquement',i:'🌸',l:'Light',s:'Rien de choquant'},
      {v:'adapté à toute la famille sans violence',i:'👨‍👩‍👧',l:'Famille',s:'Tout public'},
    ]
  },
  {
    id:'surprise',
    meta:"Étape 6 — Découverte",
    title:'Tu veux être surpris ou rester dans ta zone de confort ?',
    type:'grid',
    opts:[
      {v:'surprends-moi, je veux découvrir quelque chose de nouveau',i:'🎲',l:'Surprends-moi',s:'Nouveauté totale'},
      {v:'quelque chose dans le même style que ce que j\'aime',i:'🎯',l:'Même style',s:'Valeur sûre'},
      {v:'un mélange, dans mon genre mais avec une surprise',i:'⚖️',l:'Mélange',s:'Mi-chemin'},
    ]
  },
];
let step=0; const ans={};

function renderStep(){
  const q=QS[step];
  document.getElementById('steps').innerHTML=QS.map((_,i)=>`<div class="sdot ${i===step?'active':i<step?'done':''}"></div>`).join('');
  document.getElementById('qmeta').textContent=q.meta;
  document.getElementById('qtitle').textContent=q.title;
  const container=document.getElementById('qoptions'); container.innerHTML='';
  if(q.type==='text'){
    if(q.hint){
      const hint=document.createElement('div');
      hint.style.cssText='font-size:13px;color:var(--text3);margin-bottom:1rem;background:var(--bg2);padding:10px 14px;border-radius:8px;border-left:3px solid var(--gold)';
      hint.textContent='💡 '+q.hint;
      container.appendChild(hint);
    }
    const inp=document.createElement('input');
    inp.type='text'; inp.className='qinput';
    inp.placeholder=q.placeholder||'';
    inp.value=ans[q.id]||'';
    inp.oninput=()=>{ ans[q.id]=inp.value; };
    inp.onkeydown=e=>{ if(e.key==='Enter') nextStep(); };
    container.appendChild(inp);
    // Champ texte = optionnel → toujours actif
    document.getElementById('bnxt').disabled=false;
  } else {
    const grid=document.createElement('div'); grid.className='ogrid';
    q.opts.forEach(o=>{ const d=document.createElement('div'); d.className='opt'+(ans[q.id]===o.v?' sel':''); d.innerHTML=`<span class="oicon">${o.i}</span><span class="olab">${o.l}</span><span class="osub">${o.s}</span>`; d.onclick=()=>{ans[q.id]=o.v;renderStep();}; grid.appendChild(d); });
    container.appendChild(grid);
    document.getElementById('bnxt').disabled=!ans[q.id];
  }
  document.getElementById('bbk').style.visibility=step===0?'hidden':'visible';
  const last=step===QS.length-1;
  document.getElementById('bnxt').textContent=last?'Trouver mes films ✦':'Suivant →';
  document.getElementById('qerr').style.display='none';
}

function prevStep(){ if(step>0){step--;renderStep();} }
function nextStep(){
  const q=QS[step];
  if(q.type!=='text'&&!ans[q.id]) return;
  if(step<QS.length-1){step++;renderStep();}else launchQuiz();
}

async function launchQuiz(){
  document.getElementById('qform').style.display='none';
  document.getElementById('qload').style.display='block';
  // Nouvelles questions
  const prompt=`Tu es un expert en cinéma et séries passionné. Profil précis :
${ans.lastfilm?`- Film/série de référence : "${ans.lastfilm}" (calibre le niveau et le style)` : ''}
- Humeur : ${ans.mood}
- Engagement : ${ans.depth}
- Univers : ${ans.theme}
- Tolérance : ${ans.tolerance}
- Rapport nouveauté : ${ans.surprise}

Propose 4 films ou séries (choisis le format le plus adapté). Pour chaque :
title (français si possible), year, genre, duration, media_type ("movie" ou "tv"), reason (2 phrases perso), tags (3 mots).
JSON strict : {"intro":"...","films":[{"title":"","year":"","genre":"","duration":"","media_type":"movie","reason":"","tags":["",""]}]}`;

  let ai;
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1400,messages:[{role:'user',content:prompt}]})});
    const j=await r.json();
    const raw=j.content.map(b=>b.text||'').join('').replace(/```json|```/g,'').trim();
    ai=JSON.parse(raw);
  }catch(e){ document.getElementById('qload').style.display='none'; document.getElementById('qform').style.display='block'; showErr('qerr','Erreur IA. Réessaie.'); return; }

  for(const f of ai.films){
    f.poster=null; f.tmdbId=null;
    const st=f.media_type==='tv'?'tv':'movie';
    try{ const d=await tmdb(`/search/${st}?query=${enc(f.title)}&include_adult=false`); if(d.results&&d.results[0]){f.poster=d.results[0].poster_path;f.tmdbId=d.results[0].id;} }catch{}
  }

  const moodTxt={'aventurier et énergique':"l'aventure",'mélancolique et nostalgique':'la mélancolie','curieux et intellectuel':'la réflexion',"tendu, besoin d'adrénaline":"l'adrénaline","émotif, envie d'être touché":"l'émotion",'détendu et calme':'la détente'};
  const depthTxt={'réflexion profonde et complexe':'qui te fasse vraiment réfléchir','narration captivante du début à la fin':'qui te capture du début à la fin','beauté visuelle et atmosphère':'visuellement fort','divertissement pur sans prise de tête':'facile et agréable'};
  const surpriseTxt={'surprends-moi, je veux découvrir quelque chose de nouveau':"en dehors de ta zone habituelle","quelque chose dans le même style que ce que j'aime":'dans ton style habituel','un mélange, dans mon genre mais avec une surprise':'avec une petite touche inattendue'};

  document.getElementById('rintro').textContent=ai.intro;
  const list=document.getElementById('qflist'); list.innerHTML='';
  ai.films.forEach((f,i)=>{
    const card=document.createElement('div'); card.className='fcard';
    const st=f.media_type==='tv'?'tv':'movie';
    if(f.tmdbId) card.onclick=()=>openModal(f.tmdbId,st);
    const ph=f.poster?`<img class="fthumb" src="${IMGS}${f.poster}">`:`<div class="fthumb-ph">${st==='tv'?'📺':'🎬'}</div>`;
    const tags=(f.tags||[]).map(t=>`<span class="ftag">${esc(t)}</span>`).join('');
    const mood=moodTxt[ans.mood]||ans.mood;
    const depth=depthTxt[ans.depth]||ans.depth;
    const surp=surpriseTxt[ans.surprise]||'';
    const fmt=st==='tv'?'Cette série':'Ce film';
    const perfectText=`${fmt} est fait pour toi ce soir : il apporte ${mood}, avec quelque chose ${depth}${surp?' — '+surp:''}.`;
    const filmKey=(f.title||'').toLowerCase();
    const aw=AWARDS_DB[filmKey]||[];
    const awBadge=aw.length?`<span class="award-chip ${aw[0].cls}" style="display:inline-flex;align-items:center;gap:4px;margin-top:6px">${aw[0].ico} ${aw[0].t} ${aw[0].y}</span>`:'';
    card.innerHTML=ph+`<div class="fbody">
      <div class="fnum">Sélection ${i+1}</div>
      <div class="ftitle">${esc(f.title)}</div>
      <div class="fmeta">${[f.year,f.genre,f.duration,st==='tv'?'📺 Série':'🎬 Film'].filter(Boolean).join(' · ')}</div>
      <div class="perfect-box"><div class="perfect-ico">✨</div><div><div class="perfect-title">Parfait pour toi ce soir</div><div class="perfect-text">${perfectText}</div></div></div>
      <div class="freason">${esc(f.reason)}</div>
      <div class="ftags">${tags}${awBadge}</div>
      ${f.tmdbId?'<div class="fhint" style="margin-top:8px">Cliquer pour la fiche complète →</div>':''}
    </div>`;
    list.appendChild(card);
  });
  document.getElementById('qload').style.display='none';
  document.getElementById('qres').style.display='block';
}

/* ══ 10 FILMS SIMILAIRES triés par note & récompenses ══ */
async function loadSimilar(movieId, title, media='movie'){
  clearSearch();
  document.getElementById('sload').style.display='block';
  try{
    const ep=media==='tv'?'tv':'movie';
    const [similar, reco, det]=await Promise.all([
      tmdb(`/${ep}/${movieId}/similar`),
      tmdb(`/${ep}/${movieId}/recommendations`),
      tmdb(`/${ep}/${movieId}`)
    ]);
    const seen=new Set();
    let combined=[];
    [...(similar.results||[]),...(reco.results||[])].forEach(r=>{
      if(!seen.has(r.id)&&r.poster_path){ seen.add(r.id); combined.push({...r,_t:media}); }
    });
    // Tri : récompensés d'abord, puis par note
    combined.sort((a,b)=>{
      const aAw=(AWARDS_DB[(a.title||a.name||'').toLowerCase()]||[]).length;
      const bAw=(AWARDS_DB[(b.title||b.name||'').toLowerCase()]||[]).length;
      if(aAw!==bAw) return bAw-aAw;
      return (b.vote_average||0)-(a.vote_average||0);
    });
    combined=combined.slice(0,10);
    const dtitle=det.title||det.name||title;
    document.getElementById('rlabel').textContent=`10 titres similaires à "${dtitle}" — triés par note & récompenses`;
    const wrap=document.getElementById('flist-wrap'); wrap.innerHTML='';
    if(combined.length){
      const list=document.createElement('div'); list.className='flist';
      combined.forEach(f=>list.appendChild(makeCard(f)));
      wrap.appendChild(list);
    } else {
      wrap.innerHTML='<div class="nores"><span>🎞</span>Aucun titre similaire trouvé.</div>';
    }
    document.getElementById('rres').style.display='block';
  }catch(e){ console.error(e); showErr('serr','❌ '+e.message); }
  document.getElementById('sload').style.display='none';
}

function restartQuiz(){ step=0; Object.keys(ans).forEach(k=>delete ans[k]); document.getElementById('qres').style.display='none'; document.getElementById('qform').style.display='block'; renderStep(); }

/* ══ UTILS ══ */
function showErr(id,msg){ const e=document.getElementById(id); e.textContent=msg; e.style.display='block'; }
function enc(s){ return encodeURIComponent(s); }
function esc(s){ if(!s)return''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
</script>
</body>
</html>

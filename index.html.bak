<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>WhatMovie</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#faf7f2;--bg2:#f3ede3;--bg3:#ece4d6;
  --border:rgba(160,120,80,.15);--border2:rgba(160,120,80,.32);
  --text:#2c1f0e;--text2:#7a5c3a;--text3:#b89a78;
  --accent:#c44b2b;--accent2:#a33a1e;--abg:rgba(196,75,43,.08);
  --gold:#d4860a;--gbg:rgba(212,134,10,.1);
  --green:#2a7a4e;--shadow:rgba(100,60,20,.09);
  --blue:#2a5fa5;--bbg:rgba(42,95,165,.08);
}
html,body{min-height:100vh;background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;font-size:16px;line-height:1.6}

header{position:sticky;top:0;z-index:200;background:rgba(250,247,242,.97);backdrop-filter:blur(14px);border-bottom:1px solid var(--border);padding:0 2rem;display:flex;align-items:center;gap:2rem;height:62px;box-shadow:0 1px 14px var(--shadow)}
.logo{font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:700;color:var(--text);letter-spacing:-.5px;flex-shrink:0;cursor:pointer}
.logo em{font-style:italic;color:var(--accent)}
nav{display:flex;gap:4px;margin-left:auto}
.tab{font-size:13px;font-family:inherit;font-weight:500;color:var(--text3);background:none;border:none;border-radius:8px;padding:7px 15px;cursor:pointer;transition:color .15s,background .15s}
.tab:hover{color:var(--text2);background:var(--bg2)}
.tab.active{color:var(--accent);background:var(--abg)}

#setup-banner{background:#fff8f0;border-bottom:1px solid rgba(212,134,10,.25);padding:1rem 2rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap}
.setup-text{font-size:13px;color:var(--text2);flex:1;min-width:200px}
.setup-text strong{color:var(--gold)}
.setup-text a{color:var(--gold);text-decoration:underline}
.setup-row{display:flex;gap:8px}
.setup-inp{background:#fff;border:1px solid rgba(212,134,10,.35);border-radius:8px;color:var(--text);font-family:inherit;font-size:13px;padding:8px 12px;outline:none;width:260px}
.setup-inp:focus{border-color:var(--gold)}
.btn-save{background:var(--gold);color:#fff;font-family:inherit;font-size:13px;font-weight:500;border:none;border-radius:8px;padding:8px 16px;cursor:pointer}
.key-ok{font-size:12px;color:var(--green);font-weight:500;display:none}

main{max-width:880px;margin:0 auto;padding:2.5rem 2rem 5rem}
.page{display:none}.page.active{display:block}
h1.ptitle{font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;color:var(--text);margin-bottom:.3rem}
.psub{font-size:14px;color:var(--text3);margin-bottom:2rem}

/* BARRE */
.sbar{display:flex;gap:10px;margin-bottom:.8rem}
.swrap{flex:1;position:relative}
.swrap svg{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--text3);pointer-events:none}
.sinp{width:100%;background:#fff;border:1.5px solid var(--border);border-radius:12px;color:var(--text);font-family:inherit;font-size:15px;padding:14px 14px 14px 46px;outline:none;transition:border-color .15s,box-shadow .15s;box-shadow:0 2px 8px var(--shadow)}
.sinp::placeholder{color:var(--text3)}
.sinp:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(196,75,43,.1)}
.sinp.open{border-radius:12px 12px 0 0;border-bottom-color:transparent}
.sbtn{background:var(--accent);color:#fff;font-family:inherit;font-size:14px;font-weight:500;border:none;border-radius:12px;padding:14px 26px;cursor:pointer;white-space:nowrap;transition:background .15s,transform .1s,opacity .2s;flex-shrink:0;box-shadow:0 3px 10px rgba(196,75,43,.25)}
.sbtn:hover:not(:disabled){background:var(--accent2)}
.sbtn:active:not(:disabled){transform:scale(.97)}
.sbtn:disabled{opacity:.4;cursor:default;box-shadow:none}
.search-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:.5rem}
.search-tag{font-size:12px;padding:4px 12px;border-radius:20px;border:1px solid var(--border);background:var(--bg2);color:var(--text3)}
.shint{font-size:12px;color:var(--text3);margin-bottom:1.5rem}

/* DROPDOWN */
.sdrop{position:absolute;top:100%;left:0;right:0;z-index:400;background:#fff;border:1.5px solid var(--accent);border-top:none;border-radius:0 0 12px 12px;box-shadow:0 10px 32px rgba(100,60,20,.16);max-height:420px;overflow-y:auto;display:none}
.sdrop.open{display:block}
.drop-sec{padding:4px 0}
.drop-lbl{font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);padding:6px 14px 4px;display:flex;align-items:center;gap:8px}
.drop-lbl::after{content:'';flex:1;height:1px;background:var(--border)}
.sitem{display:flex;align-items:center;gap:12px;padding:9px 14px;cursor:pointer;border-bottom:1px solid var(--border);transition:background .1s}
.sitem:last-child{border-bottom:none}
.sitem:hover,.sitem.on{background:var(--abg)}
.sposter{width:34px;height:50px;border-radius:5px;object-fit:cover;background:var(--bg3);flex-shrink:0;border:1px solid var(--border)}
.sposter-ph{width:34px;height:50px;border-radius:5px;background:var(--bg3);border:1px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.85rem;color:var(--text3)}
.sname{flex:1;min-width:0}
.sname-t{font-size:14px;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sname-t mark{background:none;color:var(--accent);font-weight:600}
.sname-s{font-size:11px;color:var(--text3);margin-top:1px}
.sscore{font-size:11px;color:var(--text3);flex-shrink:0}

/* LOADER */
.loader{display:none;text-align:center;padding:4rem 0}
.reel{display:flex;justify-content:center;gap:5px;margin-bottom:1.5rem}
.rh{width:20px;height:28px;border:1.5px solid var(--border2);border-radius:3px;background:var(--bg2);animation:blink 1.4s ease-in-out infinite}
.rh:nth-child(1){animation-delay:0s}.rh:nth-child(2){animation-delay:.16s}.rh:nth-child(3){animation-delay:.32s}
.rh:nth-child(4){animation-delay:.48s}.rh:nth-child(5){animation-delay:.64s}.rh:nth-child(6){animation-delay:.80s}
@keyframes blink{0%,100%{opacity:.3}50%{opacity:1;border-color:var(--accent);background:var(--abg)}}
.loader-txt{font-size:14px;color:var(--text3)}

/* RÉSULTATS */
.rres{display:none}
.rmeta{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.2rem}
.rlabel{font-size:11px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--text3)}
.rclear{font-size:12px;color:var(--text3);background:none;border:none;cursor:pointer;font-family:inherit}
.rclear:hover{color:var(--accent)}

/* FICHE PERSONNE */
.actor-card{background:#fff;border:1px solid var(--border);border-radius:16px;padding:24px;margin-bottom:1.5rem;box-shadow:0 2px 12px var(--shadow);animation:fup .35s ease both}
.actor-top{display:flex;gap:20px;align-items:flex-start;margin-bottom:1.2rem}
.actor-photo{width:110px;height:110px;border-radius:50%;object-fit:cover;flex-shrink:0;border:3px solid var(--bg2);box-shadow:0 4px 16px var(--shadow)}
.actor-photo-ph{width:110px;height:110px;border-radius:50%;background:var(--bg3);border:3px solid var(--bg2);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:2.5rem;color:var(--text3)}
.actor-name{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;color:var(--text);margin-bottom:5px}
.actor-badge{display:inline-block;font-size:12px;font-weight:500;padding:3px 12px;border-radius:20px;border:1px solid var(--accent);color:var(--accent);background:var(--abg);margin-bottom:8px}
.actor-pills{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px}
.actor-pill{font-size:12px;padding:3px 10px;border-radius:20px;background:var(--bg2);border:1px solid var(--border);color:var(--text2)}

/* RÉCOMPENSES PERSONNE */
.person-awards{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:12px}
.person-award{display:flex;align-items:center;gap:5px;font-size:12px;padding:4px 12px;border-radius:20px;font-weight:500;cursor:default}
.person-award.oscar{background:#fff8e6;border:1px solid rgba(212,134,10,.4);color:#7a5200}
.person-award.cesar{background:#f0f4ff;border:1px solid rgba(80,100,200,.3);color:#3a4a9a}
.person-award.globe{background:#f0fff4;border:1px solid rgba(42,122,78,.3);color:#1a5e38}
.person-award.bafta{background:#fff0f8;border:1px solid rgba(180,50,150,.25);color:#8a1a6a}
.person-award.other{background:var(--bg2);border:1px solid var(--border);color:var(--text2)}

/* BIO */
.actor-bio{font-size:13px;color:var(--text2);line-height:1.7;background:var(--bg2);border-radius:10px;padding:14px 16px;border-left:3px solid var(--accent)}
.actor-bio.truncated{display:-webkit-box;-webkit-line-clamp:4;-webkit-box-orient:vertical;overflow:hidden}
.btn-bio{margin-top:8px;font-size:12px;font-weight:500;color:var(--accent);background:none;border:none;cursor:pointer;font-family:inherit;padding:0}
.btn-bio:hover{text-decoration:underline}

/* FILM CARD */
.flist{display:flex;flex-direction:column;gap:12px}
.fcard{display:flex;gap:16px;background:#fff;border:1px solid var(--border);border-radius:14px;padding:16px;align-items:flex-start;cursor:pointer;transition:border-color .2s,box-shadow .2s,transform .15s;animation:fup .35s ease both;box-shadow:0 2px 8px var(--shadow)}
.fcard:nth-child(2){animation-delay:.05s}.fcard:nth-child(3){animation-delay:.1s}
.fcard:nth-child(4){animation-delay:.15s}.fcard:nth-child(5){animation-delay:.2s}
.fcard:nth-child(6){animation-delay:.25s}.fcard:nth-child(7){animation-delay:.3s}
.fcard:nth-child(8){animation-delay:.35s}
@keyframes fup{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.fcard:hover{border-color:var(--accent);box-shadow:0 5px 22px rgba(196,75,43,.13);transform:translateY(-2px)}
.fthumb{width:66px;height:98px;border-radius:8px;object-fit:cover;flex-shrink:0;background:var(--bg3);border:1px solid var(--border)}
.fthumb-ph{width:66px;height:98px;border-radius:8px;background:var(--bg3);border:1px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:var(--text3)}
.fbody{flex:1;min-width:0}
.ftitle{font-family:'Playfair Display',serif;font-weight:700;font-size:1.05rem;color:var(--text);line-height:1.25;margin-bottom:3px}
.fmeta{font-size:12px;color:var(--text3);margin-bottom:6px}
.foverview{font-size:13px;color:var(--text2);line-height:1.55;margin-bottom:6px}
.fhint{font-size:11px;color:var(--accent);font-style:italic}
.fchips{display:flex;flex-wrap:wrap;gap:5px;margin-top:7px}
/* Award chips sur les cartes */
.award-chip{display:inline-flex;align-items:center;gap:4px;font-size:11px;padding:3px 9px;border-radius:20px;font-weight:500;white-space:nowrap}
.award-chip.oscar{background:#fff8e6;border:1px solid rgba(212,134,10,.4);color:#7a5200}
.award-chip.cesar{background:#f0f4ff;border:1px solid rgba(80,100,200,.3);color:#3a4a9a}
.award-chip.other{background:var(--bg2);border:1px solid var(--border);color:var(--text2)}
.chip{font-size:11px;padding:3px 10px;border-radius:20px;border:1px solid var(--border);color:var(--text3);background:var(--bg2);white-space:nowrap}
.chip.hl{border-color:rgba(196,75,43,.35);color:var(--accent);background:var(--abg)}
.chip.genre{border-color:rgba(42,95,165,.25);color:var(--blue);background:var(--bbg)}
.chip.serie{border-color:rgba(42,122,78,.25);color:var(--green);background:rgba(42,122,78,.08)}
.chip.tvshow{border-color:rgba(160,120,80,.25);color:var(--text3);background:var(--bg2)}
.fscore{font-size:12px;font-weight:600;padding:4px 10px;border-radius:20px;flex-shrink:0;margin-left:auto;align-self:flex-start}
.fscore.g{background:rgba(42,122,78,.1);color:#1a5e38;border:1px solid rgba(42,122,78,.2)}
.fscore.m{background:var(--gbg);color:#7a5200;border:1px solid rgba(212,134,10,.25)}
.fscore.l{background:var(--abg);color:var(--accent);border:1px solid rgba(196,75,43,.2)}

.nores{text-align:center;padding:4rem 0;font-size:14px;color:var(--text3);line-height:2}
.nores span{display:block;font-size:2rem;margin-bottom:.5rem}
.errbox{font-size:13px;color:var(--accent2);background:var(--abg);border:1px solid rgba(196,75,43,.2);border-radius:8px;padding:10px 14px;margin-bottom:1.2rem;display:none}

/* SECTION HEADER dans résultats */
.section-header{font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);padding:12px 0 8px;display:flex;align-items:center;gap:8px}
.section-header::after{content:'';flex:1;height:1px;background:var(--border)}

/* ════ MODAL ════ */
#overlay{position:fixed;inset:0;z-index:500;background:rgba(20,10,3,.72);backdrop-filter:blur(8px);overflow-y:auto;padding:2rem 1rem;display:none}
.modal{background:var(--bg);border-radius:20px;width:100%;max-width:820px;margin:0 auto;box-shadow:0 30px 90px rgba(20,10,3,.4);animation:min .28s cubic-bezier(.22,1,.36,1);overflow:hidden}
@keyframes min{from{opacity:0;transform:translateY(24px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}
.mban{position:relative;height:240px;background:#160a02;overflow:hidden}
.mback{width:100%;height:100%;object-fit:cover;opacity:.5;display:block}
.mback-ph{width:100%;height:100%;background:linear-gradient(135deg,#3d2005,#1a0a02)}
.mclose{position:absolute;top:14px;right:14px;width:36px;height:36px;border-radius:50%;background:rgba(0,0,0,.55);border:none;color:#fff;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:10}
.mclose:hover{background:var(--accent)}
.playbtn{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;z-index:5;gap:10px}
.playbtn:hover .playcirc{background:var(--accent);transform:scale(1.08)}
.playcirc{width:64px;height:64px;border-radius:50%;background:rgba(0,0,0,.6);border:2.5px solid rgba(255,255,255,.85);display:flex;align-items:center;justify-content:center;transition:background .2s,transform .2s}
.playtri{width:0;height:0;border:solid transparent;border-width:11px 0 11px 22px;border-left-color:#fff;margin-left:5px}
.playlbl{font-size:12px;color:rgba(255,255,255,.75);font-weight:500}
.mpwrap{position:absolute;left:24px;bottom:-58px;z-index:8}
.mposter{width:98px;height:146px;border-radius:10px;object-fit:cover;border:3px solid var(--bg);box-shadow:0 8px 28px rgba(0,0,0,.45);display:block;cursor:pointer;transition:transform .2s}
.mposter:hover{transform:scale(1.04)}
.mposter-ph{width:98px;height:146px;border-radius:10px;background:var(--bg3);border:3px solid var(--bg);box-shadow:0 8px 28px rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center;font-size:2rem;color:var(--text3)}
.mbody{padding:74px 28px 32px}
.mtitle{font-family:'Playfair Display',serif;font-size:1.75rem;font-weight:700;color:var(--text);line-height:1.2;margin-bottom:4px}
.morig{font-size:13px;color:var(--text3);font-style:italic;margin-bottom:.8rem}
.mpills{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:1rem}
.mpill{font-size:12px;padding:4px 12px;border-radius:20px;border:1px solid var(--border);background:var(--bg2);color:var(--text2)}
.mpill.serie{border-color:rgba(42,122,78,.3);color:var(--green);background:rgba(42,122,78,.08)}

/* RÉCOMPENSES MODAL */
.awards-block{background:linear-gradient(135deg,#fffbf0,#fff8e6);border:1px solid rgba(212,134,10,.25);border-radius:12px;padding:14px 16px;margin-bottom:1.2rem}
.awards-block-title{font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--gold);margin-bottom:8px;display:flex;align-items:center;gap:6px}
.awards-list{display:flex;flex-direction:column;gap:5px}
.award-item{display:flex;align-items:flex-start;gap:10px;font-size:13px;padding:6px 10px;border-radius:8px;background:rgba(255,255,255,.6)}
.award-item-ico{font-size:16px;flex-shrink:0;margin-top:1px}
.award-item-info{}
.award-item-title{font-weight:600;color:var(--text);font-size:13px}
.award-item-detail{font-size:12px;color:var(--text3);margin-top:1px}

.slabel{font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);margin-bottom:.65rem;margin-top:1.4rem}
.synopsis{font-size:14px;color:var(--text2);line-height:1.75;background:var(--bg2);border-radius:10px;padding:14px 18px;border-left:3px solid var(--accent)}
.gtags{display:flex;flex-wrap:wrap;gap:6px}
.gtag{font-size:12px;padding:4px 12px;border-radius:20px;border:1px solid var(--border2);color:var(--text2);background:var(--bg2)}
.ratings{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:1.4rem}
.rbox{display:flex;flex-direction:column;align-items:center;background:#fff;border:1px solid var(--border);border-radius:12px;padding:10px 16px;min-width:82px;box-shadow:0 1px 4px var(--shadow)}
.rsrc{font-size:10px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--text3);margin-bottom:5px}
.rval{font-size:1.25rem;font-weight:700;color:var(--text)}
.rval.gold{color:var(--gold)}.rval.green{color:var(--green)}.rval.red{color:var(--accent)}
.rsub{font-size:10px;color:var(--text3);margin-top:3px}
.stars{display:flex;gap:2px;margin:4px 0}
.star{font-size:20px;cursor:pointer;color:var(--border2);transition:color .1s,transform .1s;line-height:1}
.star:hover,.star.on{color:var(--gold);transform:scale(1.18)}
.platforms{display:flex;flex-wrap:wrap;gap:8px}
.platform{display:flex;align-items:center;gap:7px;padding:7px 14px;border-radius:10px;border:1px solid var(--border);background:#fff;font-size:13px;font-weight:500;color:var(--text2);box-shadow:0 1px 4px var(--shadow)}
.platform.best{border-color:var(--gold);background:#fffbf0}
.platform .pico{width:22px;height:22px;border-radius:5px;object-fit:contain}
.best-badge{font-size:10px;background:var(--gold);color:#fff;padding:2px 6px;border-radius:10px;margin-left:4px;font-weight:600}
.crew-row{display:flex;flex-wrap:wrap;gap:10px}
.crew-card{display:flex;align-items:center;gap:8px;background:#fff;border:1px solid var(--border);border-radius:10px;padding:8px 12px;cursor:pointer;transition:border-color .15s}
.crew-card:hover{border-color:var(--accent)}
.cphoto{width:38px;height:38px;border-radius:50%;object-fit:cover;background:var(--bg3);border:1px solid var(--border)}
.cphoto-ph{width:38px;height:38px;border-radius:50%;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:.9rem;color:var(--text3)}
.cname{font-size:13px;font-weight:500;color:var(--text)}
.cjob{font-size:11px;color:var(--text3)}
.cast-scroll{display:flex;gap:10px;overflow-x:auto;padding-bottom:8px;scrollbar-width:thin}
.cast-scroll::-webkit-scrollbar{height:4px}
.cast-scroll::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.castcard{flex-shrink:0;width:78px;cursor:pointer;text-align:center;transition:transform .15s}
.castcard:hover{transform:translateY(-3px)}
.caphoto{width:68px;height:68px;border-radius:50%;object-fit:cover;background:var(--bg3);border:2px solid var(--border);display:block;margin:0 auto 5px}
.caphoto-ph{width:68px;height:68px;border-radius:50%;background:var(--bg3);border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:1.1rem;color:var(--text3);margin:0 auto 5px}
.caname{font-size:11px;font-weight:500;color:var(--text);line-height:1.3}
.cachar{font-size:10px;color:var(--text3)}

/* QUIZ */
.steps{display:flex;gap:6px;margin-bottom:2.5rem}
.sdot{height:3px;width:28px;border-radius:2px;background:var(--border2);transition:background .3s,width .3s}
.sdot.active{background:var(--accent);width:44px}.sdot.done{background:var(--text3)}
.qmeta{font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:.4rem}
.qtitle{font-family:'Playfair Display',serif;font-weight:700;font-size:1.9rem;color:var(--text);margin-bottom:2rem;line-height:1.2}
.ogrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;margin-bottom:2.5rem}
.opt{border:1px solid var(--border);border-radius:12px;padding:1.1rem 1rem;cursor:pointer;background:#fff;transition:all .15s;text-align:center;user-select:none;box-shadow:0 1px 4px var(--shadow)}
.opt:hover{border-color:var(--border2);background:var(--bg2)}
.opt.sel{border:1.5px solid var(--accent);background:var(--abg);box-shadow:0 3px 12px rgba(196,75,43,.15)}
.opt:active{transform:scale(.97)}
.oicon{font-size:1.6rem;display:block;margin-bottom:.5rem}
.olab{font-size:13px;font-weight:500;color:var(--text);display:block}
.osub{font-size:11px;color:var(--text3);display:block;margin-top:2px}

/* Champ texte libre quiz */
.qinput{width:100%;background:#fff;border:1px solid var(--border);border-radius:10px;color:var(--text);font-family:inherit;font-size:14px;padding:12px 14px;outline:none;transition:border-color .15s;box-shadow:0 1px 4px var(--shadow);margin-bottom:2.5rem}
.qinput:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(196,75,43,.1)}
.qinput::placeholder{color:var(--text3)}

.qnav{display:flex;justify-content:space-between;align-items:center}
.bbk{background:none;border:none;color:var(--text3);font-size:13px;cursor:pointer;font-family:inherit;padding:0}
.bbk:hover{color:var(--accent)}
.bnxt{display:flex;align-items:center;gap:8px;background:var(--accent);color:#fff;font-size:14px;font-weight:500;font-family:inherit;border:none;border-radius:9px;padding:12px 26px;cursor:pointer;transition:background .15s,transform .1s,opacity .2s;box-shadow:0 3px 10px rgba(196,75,43,.3)}
.bnxt:hover:not(:disabled){background:var(--accent2)}
.bnxt:active:not(:disabled){transform:scale(.98)}
.bnxt:disabled{opacity:.35;cursor:default;box-shadow:none}
.bres{font-family:inherit;font-size:13px;color:var(--text3);background:#fff;border:1px solid var(--border);border-radius:8px;padding:9px 18px;cursor:pointer;margin-top:2rem}
.bres:hover{border-color:var(--border2)}
.rintro{font-size:14px;color:var(--text2);margin-top:.4rem;margin-bottom:1.5rem;line-height:1.6}
.fnum{font-size:10px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--accent);margin-bottom:3px}
.freason{font-size:13px;color:var(--text2);line-height:1.55}
.ftags{display:flex;flex-wrap:wrap;gap:5px;margin-top:10px}
.ftag{font-size:11px;padding:3px 10px;border-radius:20px;border:1px solid var(--border);color:var(--text3);background:var(--bg2)}
.perfect-box{background:linear-gradient(135deg,#fff8f0,#fdf3e8);border:1.5px solid rgba(212,134,10,.3);border-radius:12px;padding:14px 16px;margin-bottom:1rem;display:flex;align-items:flex-start;gap:10px}
.perfect-ico{font-size:1.4rem;flex-shrink:0;margin-top:2px}
.perfect-title{font-size:11px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--gold);margin-bottom:3px}
.perfect-text{font-size:13px;color:var(--text2);line-height:1.55}

footer{text-align:center;padding:2rem;font-size:11px;color:var(--text3);border-top:1px solid var(--border);margin-top:3rem}
footer a{color:var(--text3);text-decoration:underline}
.vbadge{display:inline-block;background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:3px 10px;font-size:11px;color:var(--text3);margin-bottom:.5rem}
</style>
</head>
<body>

<header>
  <span class="logo" onclick="goHome()">What<em>Movie</em></span>
  <nav>
    <button class="tab active" id="tab-search" onclick="switchTab('search')">🔍 Recherche</button>
    <button class="tab"        id="tab-quiz"   onclick="switchTab('quiz')">✦ Trouve ton film</button>
  </nav>
</header>

<div id="setup-banner">
  <div class="setup-text"><strong>⚙️ Configuration</strong> — Entre ta clé API TMDB gratuite. Crée-la sur <a href="https://www.themoviedb.org/settings/api" target="_blank">themoviedb.org/settings/api</a></div>
  <div class="setup-row">
    <input class="setup-inp" id="tmdb-inp" type="text" placeholder="Colle ta clé TMDB ici…"/>
    <button class="btn-save" onclick="saveKey()">Enregistrer</button>
  </div>
  <span class="key-ok" id="key-ok">✓ Enregistrée !</span>
</div>

<main>
  <div class="page active" id="page-search">
    <h1 class="ptitle">Recherche universelle</h1>
    <p class="psub">Films, séries, acteurs, réalisateurs, producteurs — tout en une seule recherche.</p>
    <div class="sbar">
      <div class="swrap" id="swrap">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input class="sinp" id="sinp" type="text" placeholder="Film, série, acteur, réalisateur…" autocomplete="off" oninput="onInp()" onkeydown="onKD(event)"/>
        <div class="sdrop" id="sdrop"></div>
      </div>
      <button class="sbtn" id="sbtn" onclick="doSearch()" disabled>Rechercher</button>
    </div>
    <div class="search-tags">
      <span class="search-tag">🎬 Films</span>
      <span class="search-tag">📺 Séries</span>
      <span class="search-tag">🎭 Acteurs</span>
      <span class="search-tag">🎥 Réalisateurs</span>
      <span class="search-tag">🎙 Producteurs</span>
    </div>
    <div class="shint">Tape au moins 2 lettres — films, séries et personnes apparaissent ensemble</div>
    <div class="errbox" id="serr"></div>
    <div class="loader" id="sload"><div class="reel"><div class="rh"></div><div class="rh"></div><div class="rh"></div><div class="rh"></div><div class="rh"></div><div class="rh"></div></div><div class="loader-txt">Recherche en cours…</div></div>
    <div class="rres" id="rres">
      <div class="rmeta"><div class="rlabel" id="rlabel"></div><button class="rclear" onclick="clearSearch()">✕ Effacer</button></div>
      <div id="actor-detail"></div>
      <div id="flist-wrap"></div>
    </div>
  </div>

  <div class="page" id="page-quiz">
    <div id="qform">
      <div class="steps" id="steps"></div>
      <div class="qmeta" id="qmeta"></div>
      <div class="qtitle" id="qtitle"></div>
      <div class="errbox" id="qerr"></div>
      <div id="qoptions"></div>
      <div class="qnav">
        <button class="bbk" id="bbk" onclick="prevStep()">← Retour</button>
        <button class="bnxt" id="bnxt" onclick="nextStep()">Suivant →</button>
      </div>
    </div>
    <div class="loader" id="qload"><div class="reel"><div class="rh"></div><div class="rh"></div><div class="rh"></div><div class="rh"></div><div class="rh"></div><div class="rh"></div></div><div class="loader-txt">L'IA analyse ton profil…</div></div>
    <div id="qres" style="display:none">
      <h1 class="ptitle">Tes sélections du soir</h1>
      <div class="rintro" id="rintro"></div>
      <div class="flist" id="qflist"></div>
      <button class="bres" onclick="restartQuiz()">↺ Recommencer</button>
    </div>
  </div>
</main>

<!-- MODAL -->
<div id="overlay" onclick="overlayClick(event)">
  <div class="modal" id="modal">
    <div class="mban">
      <div id="mback"><div class="mback-ph"></div></div>
      <div class="playbtn" id="playbtn" onclick="openTrailer()">
        <div class="playcirc"><div class="playtri"></div></div>
        <div class="playlbl" id="playlbl">▶ Bande-annonce</div>
      </div>
      <button class="mclose" onclick="closeModal()">✕</button>
      <div class="mpwrap" id="mpwrap"><div class="mposter-ph">🎬</div></div>
    </div>
    <div class="mbody">
      <div class="mtitle" id="mtitle">Chargement…</div>
      <div class="morig"  id="morig"></div>
      <div class="mpills" id="mpills"></div>
      <div id="mawards-block"></div>
      <div class="ratings" id="mratings"></div>
      <div class="slabel">Synopsis</div>
      <div class="synopsis" id="msynopsis">Chargement…</div>
      <div class="slabel">Genres</div>
      <div class="gtags" id="mgenres"></div>
      <div class="slabel">Où regarder</div>
      <div id="plat-label" style="font-size:11px;color:var(--text3);margin-bottom:.5rem"></div>
      <div class="platforms" id="mplatforms"></div>
      <div class="slabel">Réalisation & Production</div>
      <div class="crew-row" id="mcrew"></div>
      <div class="slabel">Acteurs principaux</div>
      <div class="cast-scroll" id="mcast"></div>
    </div>
  </div>
</div>

<footer><div class="vbadge">v8.0</div><br>WhatMovie — <a href="https://www.anthropic.com" target="_blank">Claude AI</a> &amp; <a href="https://www.themoviedb.org" target="_blank">TMDB</a></footer>

<script>
